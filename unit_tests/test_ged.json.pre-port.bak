    {
      "id": "babio3_vs_ba3pbo_ged",
      "type": "ged",
      "description": "BaBiO3 (perovskite) vs Ba3PbO (antiperovskite): identical bond topology, inverted cation/anion roles. Role-swap trial should detect the equivalence and return cost ~0. Correct mapping: O\u00d73\u2194Ba\u00d73, Bi\u2194O, Ba\u2194Pb.",
      "graph_a": "BaBiO3_mp-545783",
      "graph_b": "Ba3PbO_mp-29242",
      "cif_a": "BaBiO3_mp-545783.cif",
      "cif_b": "Ba3PbO_mp-29242.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Perovskite and antiperovskite share identical bond topology \u2014 cost must be near zero after role-swap trial",
          "op": "le",
          "value": 0.05
        },
        {
          "assert": "unassigned_a_count",
          "description": "All BaBiO3 nodes have a topological counterpart in Ba3PbO",
          "op": "le",
          "value": 0
        },
        {
          "assert": "unassigned_b_count",
          "description": "All Ba3PbO nodes have a topological counterpart in BaBiO3",
          "op": "le",
          "value": 0
        },
        {
          "assert": "vacancy_a_count",
          "description": "Perfect-match case: all A-atoms must be mapped (no free vacancies)",
          "op": "le",
          "value": 0.0
        },
        {
          "assert": "vacancy_b_count",
          "description": "Perfect-match case: all B-atoms must be mapped (no free vacancies)",
          "op": "le",
          "value": 0.0
        }
      ],
      "tags": [
        "core"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
