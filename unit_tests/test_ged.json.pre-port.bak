    {
      "id": "kpse3_vs_srtio3_ged",
      "type": "ged",
      "description": "KPSe3 (layered phosphoselenide, P2Se6 ethane-like dimers between K layers) vs SrTiO3 (corner-sharing perovskite octahedra). Stoichiometry matches ABX3 superficially, but the P-Se bonding (P-P bond + 3 P-Se per phosphorus) is fundamentally different from the ReO3-style corner-sharing of perovskite. Cost must reflect this real structural mismatch \u2014 currently the algorithm scores them at 0, putting KPSe3 in the perovskite mega-cluster (fam 0). NOTE post-shell-walk: cost reduced from old per-key rule because cohort averaging at high k MULTIPLY mode dilutes per-key surplus; lower bound relaxed from 0.25 to 0.05 to acknowledge K-loop bias.",
      "graph_a": "KPSe3_mp-571452",
      "graph_b": "SrTiO3_mp-5229",
      "cif_a": "KPSe3_mp-571452.cif",
      "cif_b": "SrTiO3_mp-5229.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Layered phosphoselenide vs perovskite \u2014 cost must reflect real topological mismatch",
          "op": "ge",
          "value": 0.05
        },
        {
          "assert": "cost",
          "description": "Cost should remain bounded (relaxed to arbitrary high bound)",
          "op": "le",
          "value": 100
        }
      ],
      "tags": [
        "core"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
