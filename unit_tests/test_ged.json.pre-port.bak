    {
      "id": "al2cuo4_vs_al2znse4",
      "type": "ged",
      "description": "Al2CuO4 (spinel Fd-3m) vs Al2ZnSe4 (sphalerite-derived corner-sharing tetrahedral framework).  Same A2BX4 stoichiometry but completely different topology: spinel has Al(CN=6) edge+corner-sharing octahedra and Cu(CN=4) tetrahedra, while Al2ZnSe4 has all cations at CN=4 (corner-sharing tetrahedra only) and Se anions at CN=3 instead of CN=4.  Pre-shell-walk this scored 0.0 under TopologyCost (cohort-averaging + per-key NN-rectification let CN=6 atoms map onto CN=4 cohort slots without charging); post-shell-walk this is correctly identified as a topology mismatch.  Test pins the multi-lens response so future cost-function work doesn't regress on this user-identified false positive.",
      "graph_a": "Al2CuO4_mp-27719",
      "graph_b": "Al2ZnSe4_mp-7907",
      "cif_a": "Al2CuO4_mp-27719.cif",
      "cif_b": "Al2ZnSe4_mp-7907.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Spinel vs sphalerite-derived 1:2:4 framework \u2014 topology cost must reflect the CN-mismatch (CN=6 octahedra in spinel vs CN=4 tetrahedra in Al2ZnSe4)",
          "op": "ge",
          "value": 0.5
        },
        {
          "assert": "cost",
          "description": "Cost should remain bounded (relaxed to arbitrary high bound)",
          "op": "le",
          "value": 100
        },
        {
          "assert": "cost_polyhedral",
          "description": "Polyhedral lens must clearly distinguish: spinel has corner+edge sharing, Al2ZnSe4 has corner-only",
          "op": "ge",
          "value": 1.0
        },
        {
          "assert": "cost_bond_length",
          "description": "Different B-X bond lengths (Al-O ~1.9 \u00c5 vs Al/Zn-Se ~2.4-2.5 \u00c5) must register",
          "op": "ge",
          "value": 0.5
        }
      ],
      "tags": [
        "cost_lens"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
    {
