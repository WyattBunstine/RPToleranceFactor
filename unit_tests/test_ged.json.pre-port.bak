          "value": 100
        }
      ],
      "tags": [
        "core"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
    {
      "id": "baal2o4_polymorphs_ged",
      "type": "ged",
      "description": "BaAl2O4 mp-4202 (56 atoms, 8 FU) vs BaAl2O4 mp-3828 (14 atoms, 2 FU): same compound, related by a 4\u00d7 supercell ratio (k=4 expected from the k-loop).  Both are corner-sharing AlO\u2084 tetrahedral frameworks with Ba in the channels \u2014 identical primary-bond topology.  Under TopologyCost the comparison should score essentially zero.  Currently regresses the L1 unsupervised clustering: these two polymorphs land in different families (F14 and F19, both singletons in data/families_v4.json) because the algorithm picks k=1 (cost ~46) over the physically-correct k=4 (cost ~224 due to MULTIPLY-mode unforced_unassigned bin penalties).  Tracks the MULTIPLY-mode assignment-failure bug surfaced 2026-05-04.",
      "graph_a": "BaAl2O4_mp-4202",
      "graph_b": "BaAl2O4_mp-3828",
      "cif_a": "BaAl2O4_mp-4202.cif",
      "cif_b": "BaAl2O4_mp-3828.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Isostructural BaAl2O4 polymorphs (same corner-sharing AlO4 framework, just different cell sizes): topological cost must be near zero",
          "op": "le",
          "value": 0.05
        },
        {
          "assert": "cross_fu_k",
          "description": "k-loop should select k=4: 8 FU cell vs 2 FU cell, ratio 4",
          "op": "in",
          "min": 4,
          "max": 4
        },
        {
          "assert": "unassigned_a_count",
          "description": "Same topology under correct k: every A-side atom must be mapped",
          "op": "le",
          "value": 0
        },
        {
          "assert": "unassigned_b_count",
          "description": "Same topology under correct k: every B-side atom must be mapped",
          "op": "le",
          "value": 0
        },
        {
          "assert": "vacancy_a_count",
          "description": "No vacancies expected for an isostructural supercell pair",
          "op": "le",
          "value": 0
        },
        {
          "assert": "vacancy_b_count",
          "description": "No vacancies expected for an isostructural supercell pair",
          "op": "le",
          "value": 0
        }
      ],
      "tags": [
        "core"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
    {
      "id": "kpse3_polymorphs_vs_srtio3_consistency",
      "type": "ged_consistency",
      "description": "All KPSe3/RbPSe3 polymorphs (layered phosphoselenides) compared against cubic SrTiO3 perovskite. Every polymorph must score well above 1 \u2014 the layered P2Se6-dimer topology is fundamentally different from corner-sharing perovskite octahedra, regardless of cell size or distortion variant.",
      "reference": "SrTiO3_mp-5229",
      "reference_cif": "SrTiO3_mp-5229.cif",
      "candidates": [
