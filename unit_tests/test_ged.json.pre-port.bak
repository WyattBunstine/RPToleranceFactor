      "graph_b": "Sr4Ti3O10_mp-31213",
      "cif_a": "Sr2TiO4_mp-5532.cif",
      "cif_b": "Sr4Ti3O10_mp-31213.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "k=2 normalized: RP n=1 vs RP n=3 have more similar environments than perovskite vs RP n=3, moderate cost (relaxed to arbitrary high bound)",
          "op": "le",
          "value": 100
        },
        {
          "assert": "cost",
          "description": "Cost should be non-trivial (different n in RP series, extra TiO2 and SrO layers)",
          "op": "ge",
          "value": 3.0
        },
        {
          "assert": "cross_fu_k",
          "description": "k=2: two RP-214 FUs (14 atoms) cover most of RP-313 (17 atoms), 3 extras",
          "op": "in",
          "min": 2,
          "max": 2
        },
        {
          "assert": "map_element",
          "src_element": "Sr",
          "tgt_element": "Sr",
          "description": "Sr in RP-214 maps to Sr in RP-313"
        },
        {
          "assert": "map_element",
          "src_element": "Ti",
          "tgt_element": "Ti",
          "description": "Ti in RP-214 maps to Ti in RP-313"
        }
      ],
      "tags": [
        "formula_unit"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
