    {
      "id": "reo3_vs_batio3_site_mapping",
      "type": "ged",
      "description": "ReO3 vs BaTiO3 (cubic Pm-3m): Re must map to Ti (B-site), O must map to O, Ba (A-site) has no ReO3 counterpart",
      "graph_a": "ReO3_mp-547271",
      "graph_b": "BaTiO3_mp-5020",
      "cif_a": "ReO3_mp-547271.cif",
      "cif_b": "BaTiO3_mp-5020.cif",
      "assertions": [
        {
          "assert": "map_element",
          "src_element": "Re",
          "tgt_element": "Ti",
          "description": "Re (B-site in ReO3) must map to Ti (B-site in BaTiO3)"
        },
        {
          "assert": "map_element",
          "src_element": "O",
          "tgt_element": "O",
          "description": "O in ReO3 must map to O in BaTiO3"
        },
        {
          "assert": "vacancy_b_all_element",
          "element": "Ba",
          "description": "Ba (A-site) has no counterpart in ReO3 \u2014 all Ba nodes must be in vacancy_b"
        }
      ],
      "tags": [
        "defect"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
    {
      "id": "reo3_vs_ktao3_site_mapping",
