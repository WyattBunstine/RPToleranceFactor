    {
      "id": "srtio3_vs_tifeo3_ged",
      "type": "ged",
      "description": "SrTiO3 (perovskite) vs TiFeO3 (ilmenite): corner-sharing vs face/edge-sharing \u2014 structurally unrelated families",
      "graph_a": "SrTiO3_mp-5229",
      "graph_b": "TiFeO3_mp-19270",
      "cif_a": "SrTiO3_mp-5229.cif",
      "cif_b": "TiFeO3_mp-19270.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Perovskite vs ilmenite: bond topology mismatch should produce significant cost",
          "op": "ge",
          "value": 1.0
        },
        {
          "assert": "cost",
          "description": "Cost should remain bounded (not unbounded for unrelated structures) (relaxed to arbitrary high bound)",
          "op": "le",
          "value": 100
        }
      ],
      "tags": [
        "core"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
