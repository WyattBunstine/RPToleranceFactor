    {
      "id": "ybco_vs_srtio3_ged",
      "type": "ged",
      "description": "Ba2YCu3O7 (distorted/deficient perovskite, 13 atoms/FU) vs SrTiO3 (cubic Pm-3m, 5 atoms/FU): same perovskite topology, k-loop selects k=3 (3 SrTiO3 FUs per one YBCO FU). Cost reflects averaging over 3 rounds.",
      "graph_a": "Ba2YCu3O7_mp-20674",
      "graph_b": "SrTiO3_mp-5229",
      "cif_a": "Ba2YCu3O7_mp-20674.cif",
      "cif_b": "SrTiO3_mp-5229.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "YBCO vs SrTiO3: k=3 normalized cost, bounded below 7.0",
          "op": "le",
          "value": 7.0
        },
        {
          "assert": "cross_fu_k",
          "description": "k-loop should select k=3 (3 perovskite FUs per one YBCO FU)",
          "op": "in",
          "min": 3,
          "max": 3
        },
        {
          "assert": "map_element",
          "src_element": "Cu",
          "tgt_element": "Ti",
          "description": "All Cu (B-site in YBCO, including square-planar CN=4 via vacancy-inflation) must map to Ti (B-site in SrTiO3)"
        }
      ],
      "tags": [
        "defect"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
