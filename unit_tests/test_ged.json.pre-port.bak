          "cif": "RbPSe3_mp-571464.cif"
        }
      ],
      "assertions": [
        {
          "assert": "cost_min",
          "description": "Every KPSe3/RbPSe3 polymorph must score well above 1 against perovskite SrTiO3 \u2014 no polymorph should slip into the perovskite cluster (post-shell-walk: lower bound relaxed because cohort averaging at high-k MULTIPLY can dilute per-key surplus)",
