{
  "$schema": "unit_test_suite_v1",
  "version": "1",
  "graph_builder": "crystal_graph_v4",
  "description": "GED node-matching tests (match_nodes_ged) \u2014 cost, unassigned counts",
  "cif_root": "data/cifs",
  "graph_cache_dir": "unit_tests/graphs",
  "tests": [
    {
      "id": "srtio3_vs_srtio3_ged",
      "type": "ged",
      "description": "SrTiO3 vs itself: self-comparison must return cost=0 with all nodes assigned",
      "graph_a": "SrTiO3_mp-5229",
      "graph_b": "SrTiO3_mp-5229",
      "cif_a": "SrTiO3_mp-5229.cif",
      "cif_b": "SrTiO3_mp-5229.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Self-comparison must return exactly zero cost",
          "op": "le",
          "value": 0.0
        },
        {
          "assert": "unassigned_a_count",
          "description": "No unassigned A-nodes in self-comparison",
          "op": "le",
          "value": 0
        },
        {
          "assert": "unassigned_b_count",
          "description": "No unassigned B-nodes in self-comparison",
          "op": "le",
          "value": 0
        },
        {
          "assert": "vacancy_a_count",
          "description": "Perfect-match case: all A-atoms must be mapped (no free vacancies)",
          "op": "le",
          "value": 0.0
        },
        {
          "assert": "vacancy_b_count",
          "description": "Perfect-match case: all B-atoms must be mapped (no free vacancies)",
          "op": "le",
          "value": 0.0
        }
      ],
      "tags": [
        "core",
        "smoke"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
    {
      "id": "srtio3_vs_batio3_ged",
      "type": "ged",
      "description": "SrTiO3 vs BaTiO3 (both cubic Pm-3m perovskite): identical bond topology, cost should be ~0",
      "graph_a": "SrTiO3_mp-5229",
      "graph_b": "BaTiO3_mp-5020",
      "cif_a": "SrTiO3_mp-5229.cif",
      "cif_b": "BaTiO3_mp-5020.cif",
      "assertions": [
        {
          "assert": "cost",
          "description": "Isostructural cubic perovskites: bond topology is identical, cost must be near zero",
          "op": "le",
          "value": 0.05
        },
        {
          "assert": "unassigned_a_count",
          "description": "Same formula unit size: all A-nodes must be assigned",
          "op": "le",
          "value": 0
        },
        {
          "assert": "unassigned_b_count",
          "description": "Same formula unit size: all B-nodes must be assigned",
          "op": "le",
          "value": 0
        },
        {
          "assert": "vacancy_a_count",
          "description": "Perfect-match case: all A-atoms must be mapped (no free vacancies)",
          "op": "le",
          "value": 0.0
        },
        {
          "assert": "vacancy_b_count",
          "description": "Perfect-match case: all B-atoms must be mapped (no free vacancies)",
          "op": "le",
          "value": 0.0
        }
      ],
      "tags": [
        "core"
      ],
      "optimizer": "v1",
      "cost_function": "v1"
    },
